          const status = document.getElementById('cat_status').value;
          const showOnCareers = document.getElementById('cat_showCareers').checked;

          cache.categories[key] = {
            id: key,
            slug: key,
            name,
            description,
            shortDescription: description,
            icon,
            bannerImage,
            order,
            status,
            showOnCareers,
            published: status === 'Active' && showOnCareers,
          };

          syncCareerCategoryOptions(name);

          await authFetch(endpoints['job-categories'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cache.categories),
          });

          setStatus(editState.categories ? 'Job category updated successfully.' : 'Job category added successfully.', 'ok');
          setCategoryEditing(null);
          clearCategoryForm();
          renderCategoriesList();
        } catch (error) {
          setStatus(error.message || 'Failed to save category', 'err');
        }
      }

      // ---------- CAREER PAGE SETTINGS ----------

      function createBenefitItem(data = {}) {
        const item = document.createElement('div');
        item.className = 'repeat-item grid';
        item.innerHTML = `
          <div class="cols-3">
            <div><p class="field-label">Icon</p><input data-field="icon" value="${escapeHtml(data.icon || '')}" /></div>
            <div><p class="field-label">Benefit Title</p><input data-field="title" value="${escapeHtml(data.title || '')}" /></div>
            <div><p class="field-label">Display Order</p><input data-field="order" type="number" value="${data.order || 0}" /></div>
            <div style="grid-column:1/-1;"><p class="field-label">Benefit Description</p><textarea data-field="description">${escapeHtml(data.description || '')}</textarea></div>
            <div><p class="field-label">Status</p><select data-field="status"><option ${data.status === 'Inactive' ? '' : 'selected'}>Active</option><option ${data.status === 'Inactive' ? 'selected' : ''}>Inactive</option></select></div>
          </div>
          <div class="row"><button class="btn" data-remove>Remove Benefit</button></div>
        `;
        item.querySelector('[data-remove]').addEventListener('click', () => item.remove());
        return item;
      }

      function createStepItem(data = {}) {
        const item = document.createElement('div');
        item.className = 'repeat-item grid';
        item.innerHTML = `
          <div class="cols-3">
            <div><p class="field-label">Step Number</p><input data-field="stepNumber" type="number" value="${data.stepNumber || 1}" /></div>
            <div><p class="field-label">Step Title</p><input data-field="title" value="${escapeHtml(data.title || '')}" /></div>
            <div><p class="field-label">Icon</p><input data-field="icon" value="${escapeHtml(data.icon || '')}" /></div>
            <div style="grid-column:1/-1;"><p class="field-label">Step Description</p><textarea data-field="description">${escapeHtml(data.description || '')}</textarea></div>
            <div><p class="field-label">Status</p><select data-field="status"><option ${data.status === 'Inactive' ? '' : 'selected'}>Active</option><option ${data.status === 'Inactive' ? 'selected' : ''}>Inactive</option></select></div>
          </div>
          <div class="row"><button class="btn" data-remove>Remove Step</button></div>
        `;
        item.querySelector('[data-remove]').addEventListener('click', () => item.remove());
        return item;
      }

      function collectRepeatItems(containerId) {
        const container = document.getElementById(containerId);
        return Array.from(container.children).map(item => {
          const fields = item.querySelectorAll('[data-field]');
          const out = {};
          fields.forEach(field => {
            const key = field.getAttribute('data-field');
            out[key] = field.type === 'number' ? Number(field.value || 0) : field.value;
          });
          return out;
        });
      }

      async function saveCareerSettings() {
        try {
          const payload = {
            hero: {
              title: document.getElementById('set_heroTitle').value.trim(),
              subtitle: document.getElementById('set_heroSubtitle').value.trim(),
              bannerImage: document.getElementById('set_heroBannerImage').value.trim(),
              backgroundImage: document.getElementById('set_heroBackgroundImage').value.trim(),
            },
            whyJoin: {
              title: document.getElementById('set_whyTitle').value.trim(),
              description: document.getElementById('set_whyDescription').value.trim(),
            },
            benefits: collectRepeatItems('benefitsList'),
            applicationProcess: collectRepeatItems('appStepsList'),
            contact: {
              email: document.getElementById('set_contactEmail').value.trim(),
              officeLocation: document.getElementById('set_officeLocation').value.trim(),
              phone: document.getElementById('set_contactPhone').value.trim(),
              googleMaps: document.getElementById('set_googleMaps').value.trim(),
            },
            equalOpportunityContent: document.getElementById('set_equalOpportunity').value.trim(),
            visibility: {
              enableCareerPage: document.getElementById('set_enableCareerPage').checked,
              showOpenPositionsSection: document.getElementById('set_showOpenPositions').checked,
              showBenefitsSection: document.getElementById('set_showBenefits').checked,
              showApplicationProcess: document.getElementById('set_showApplicationProcess').checked,
              showContactSection: document.getElementById('set_showContact').checked,
              showDownloadsSection: document.getElementById('set_showDownloads').checked,
            },
            seo: {
              title: document.getElementById('set_seoTitle').value.trim(),
              description: document.getElementById('set_seoDescription').value.trim(),
              keywords: splitTags(document.getElementById('set_seoKeywords').value),
              openGraphImage: document.getElementById('set_ogImage').value.trim(),
            },
            hero_title: document.getElementById('set_heroTitle').value.trim(),
            hero_subtitle: document.getElementById('set_heroSubtitle').value.trim(),
            why_join_title: document.getElementById('set_whyTitle').value.trim(),
            why_join_description: document.getElementById('set_whyDescription').value.trim(),
            application_title: 'How to Apply',
            application_instructions: document.getElementById('set_whyDescription').value.trim(),
            contact_email: document.getElementById('set_contactEmail').value.trim(),
            office_location: document.getElementById('set_officeLocation').value.trim(),
          };

          await authFetch(endpoints['career-page-settings'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          setStatus('Career page settings saved.', 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to save settings', 'err');
        }
      }

      async function loadCareerSettings() {
        try {
          const data = await authFetch(endpoints['career-page-settings']);
          const hero = data.hero || {};
          const whyJoin = data.whyJoin || {};
          const contact = data.contact || {};
          const visibility = data.visibility || {};
          const seo = data.seo || {};

          document.getElementById('set_heroTitle').value = hero.title || data.hero_title || '';
          document.getElementById('set_heroSubtitle').value = hero.subtitle || data.hero_subtitle || '';
          document.getElementById('set_heroBannerImage').value = hero.bannerImage || '';
          document.getElementById('set_heroBackgroundImage').value = hero.backgroundImage || '';
          document.getElementById('set_whyTitle').value = whyJoin.title || data.why_join_title || '';
          document.getElementById('set_whyDescription').value = whyJoin.description || data.why_join_description || '';
          document.getElementById('set_contactEmail').value = contact.email || data.contact_email || '';
          document.getElementById('set_officeLocation').value = contact.officeLocation || data.office_location || '';
          document.getElementById('set_contactPhone').value = contact.phone || '';
          document.getElementById('set_googleMaps').value = contact.googleMaps || '';
          document.getElementById('set_equalOpportunity').value = data.equalOpportunityContent || '';
          document.getElementById('set_enableCareerPage').checked = visibility.enableCareerPage !== false;
          document.getElementById('set_showOpenPositions').checked = visibility.showOpenPositionsSection !== false;
          document.getElementById('set_showBenefits').checked = visibility.showBenefitsSection !== false;
          document.getElementById('set_showApplicationProcess').checked = visibility.showApplicationProcess !== false;
          document.getElementById('set_showContact').checked = visibility.showContactSection !== false;
          document.getElementById('set_showDownloads').checked = visibility.showDownloadsSection !== false;
          document.getElementById('set_seoTitle').value = seo.title || '';
          document.getElementById('set_seoDescription').value = seo.description || '';
          document.getElementById('set_seoKeywords').value = Array.isArray(seo.keywords) ? seo.keywords.join(', ') : '';
          document.getElementById('set_ogImage').value = seo.openGraphImage || '';

          const benefitsList = document.getElementById('benefitsList');
          benefitsList.innerHTML = '';
          (data.benefits || []).forEach(item => benefitsList.appendChild(createBenefitItem(item)));
          if (!benefitsList.children.length) benefitsList.appendChild(createBenefitItem());

          const appStepsList = document.getElementById('appStepsList');
          appStepsList.innerHTML = '';
          (data.applicationProcess || []).forEach(item => appStepsList.appendChild(createStepItem(item)));
          if (!appStepsList.children.length) appStepsList.appendChild(createStepItem());

          setStatus('Career page settings loaded.', 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to load settings', 'err');
        }
      }

      // ---------- DOWNLOADABLE GUIDES ----------

      function populateGuideForm(item) {
        document.getElementById('guide_title').value = item.title || '';
        document.getElementById('guide_slug').value = item.slug || '';
        document.getElementById('guide_slug').dataset.touched = 'true';
        document.getElementById('guide_description').value = item.description || '';
        document.getElementById('guide_category').value = item.category || '';
        document.getElementById('guide_type').value = item.guideType || '';
        document.getElementById('guide_thumbnail').value = item.thumbnailImage || '';
        document.getElementById('guide_cover').value = item.coverImage || '';
        document.getElementById('guide_file').value = item.pdfFile || '';
        document.getElementById('guide_buttonText').value = item.buttonText || 'Download';
        document.getElementById('guide_externalUrl').value = item.externalDownloadUrl || '';
        document.getElementById('guide_featured').checked = !!item.featured;
        document.getElementById('guide_order').value = item.order || 1;
        document.getElementById('guide_status').value = item.status || 'Active';
        document.getElementById('guide_trackDownloads').checked = item.trackDownloads !== false;
        document.getElementById('guide_downloadCount').value = item.downloadCount || 0;
        const seo = item.seo || {};
        document.getElementById('guide_seoTitle').value = seo.title || '';
        document.getElementById('guide_seoDescription').value = seo.description || '';
        document.getElementById('guide_seoKeywords').value = Array.isArray(seo.keywords) ? seo.keywords.join(', ') : '';
      }

      function clearGuideForm() {
        ['guide_title','guide_slug','guide_description','guide_thumbnail','guide_cover','guide_file',
         'guide_externalUrl','guide_seoTitle','guide_seoDescription','guide_seoKeywords'].forEach(id => {
          document.getElementById(id).value = '';
        });
        document.getElementById('guide_slug').dataset.touched = '';
        document.getElementById('guide_buttonText').value = 'Download';
        document.getElementById('guide_featured').checked = false;
        document.getElementById('guide_order').value = 1;
        document.getElementById('guide_status').selectedIndex = 0;
        document.getElementById('guide_trackDownloads').checked = true;
        document.getElementById('guide_downloadCount').value = 0;
        document.getElementById('guide_category').selectedIndex = 0;
        document.getElementById('guide_type').selectedIndex = 0;
      }

      function setGuideEditing(key) {
        editState.guides = key;
        const title = document.getElementById('guideFormTitle');
        const saveBtn = document.getElementById('guideSaveBtn');
        const cancelBtn = document.getElementById('guideCancelBtn');
        if (key) {
          title.textContent = 'Edit Downloadable Guide';
          saveBtn.textContent = 'Update Guide';
          cancelBtn.classList.remove('hidden');
        } else {
          title.textContent = 'Add Downloadable Guide';
          saveBtn.textContent = 'Add Guide';
          cancelBtn.classList.add('hidden');
        }
      }

      function editGuide(key) {
        const item = cache.guides[key];
        if (!item) return;
        populateGuideForm(item);
        setGuideEditing(key);
        document.getElementById('guideFormTitle').scrollIntoView({ behavior: 'smooth', block: 'start' });
        renderGuidesList();
      }

      async function deleteGuide(key) {
        const item = cache.guides[key];
        if (!confirm('Delete guide "' + (item && item.title ? item.title : key) + '"? This cannot be undone.')) return;
        try {
          delete cache.guides[key];
          await authFetch(endpoints['downloadable-guides'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cache.guides),
          });
          if (editState.guides === key) {
            setGuideEditing(null);
            clearGuideForm();
          }
          renderGuidesList();
          document.getElementById('guidesEditor').value = JSON.stringify(cache.guides, null, 2);
          setStatus('Guide deleted.', 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to delete guide', 'err');
        }
      }

      function renderGuidesList() {
        const container = document.getElementById('guidesList');
        const keys = Object.keys(cache.guides || {});
        if (!keys.length) {
          container.innerHTML = '<div class="empty-state">No guides yet. Use the form below to add one.</div>';
          return;
        }
        container.innerHTML = '';
        keys.forEach(key => {
          const item = cache.guides[key] || {};
          const meta = [item.category, item.guideType, item.featured ? 'Featured' : '']
            .filter(Boolean)
            .map(v => `<span>${escapeHtml(v)}</span>`)
            .join('');
          const row = document.createElement('div');
          row.className = 'list-item' + (editState.guides === key ? ' editing' : '');
          row.innerHTML = `
            <div class="list-card-header">
              <div class="list-item-title">${escapeHtml(item.title || key)}</div>
              <span class="badge ${item.status !== 'Inactive' ? 'on' : 'off'}">${escapeHtml(item.status || 'Active')}</span>
            </div>
            <div class="list-item-meta">${meta || '<span>No details set</span>'}</div>
            <div class="list-card-actions">
              <button class="btn btn-sm" data-edit>Edit</button>
              <button class="btn btn-sm btn-danger" data-delete>Delete</button>
            </div>
          `;
          row.querySelector('[data-edit]').addEventListener('click', () => editGuide(key));
          row.querySelector('[data-delete]').addEventListener('click', () => deleteGuide(key));
          container.appendChild(row);
        });
      }

      async function refreshGuidesList() {
        try {
          const data = await authFetch(endpoints['downloadable-guides']);
          cache.guides = Array.isArray(data) ? {} : Object.assign({}, data || {});
          renderGuidesList();
          document.getElementById('guidesEditor').value = JSON.stringify(cache.guides, null, 2);
        } catch (error) {
          setStatus(error.message || 'Failed to load guides', 'err');
        }
      }

      async function saveGuide() {
        try {
          const title = document.getElementById('guide_title').value.trim();
          if (!title) throw new Error('Guide Title is required');
          const slugInput = document.getElementById('guide_slug').value.trim();
          const key = editState.guides || slugInput || slugify(title);
          const description = document.getElementById('guide_description').value.trim();
          if (!description) throw new Error('Short Description is required');

          const existing = editState.guides ? (cache.guides[editState.guides] || {}) : {};

          cache.guides[key] = Object.assign({}, existing, {
            slug: key,
            title,
            description,
            category: document.getElementById('guide_category').value,
            guideType: document.getElementById('guide_type').value,
            thumbnailImage: document.getElementById('guide_thumbnail').value.trim(),
            coverImage: document.getElementById('guide_cover').value.trim(),
            pdfFile: document.getElementById('guide_file').value.trim(),
            buttonText: document.getElementById('guide_buttonText').value.trim() || 'Download',
            externalDownloadUrl: document.getElementById('guide_externalUrl').value.trim(),
            featured: document.getElementById('guide_featured').checked,
            order: Number(document.getElementById('guide_order').value || 1),
            status: document.getElementById('guide_status').value,
            published: document.getElementById('guide_status').value === 'Active',
            trackDownloads: document.getElementById('guide_trackDownloads').checked,
            downloadCount: Number(document.getElementById('guide_downloadCount').value || 0),
            seo: {
              title: document.getElementById('guide_seoTitle').value.trim(),
              description: document.getElementById('guide_seoDescription').value.trim(),
              keywords: splitTags(document.getElementById('guide_seoKeywords').value),
            },
            icon: document.getElementById('guide_thumbnail').value.trim(),
            date: existing.date || new Date().toISOString(),
          });

          document.getElementById('guidesEditor').value = JSON.stringify(cache.guides, null, 2);

          await authFetch(endpoints['downloadable-guides'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cache.guides),
          });

          setStatus(editState.guides ? 'Guide updated successfully.' : 'Guide added successfully.', 'ok');
          setGuideEditing(null);
          clearGuideForm();
          renderGuidesList();
        } catch (error) {
          setStatus(error.message || 'Failed to save guide', 'err');
        }
      }

      async function loadGuidesJson() {
        try {
          const data = await authFetch(endpoints['downloadable-guides']);
          cache.guides = Array.isArray(data) ? {} : Object.assign({}, data || {});
          document.getElementById('guidesEditor').value = JSON.stringify(cache.guides, null, 2);
          renderGuidesList();
          setStatus('Guides loaded.', 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to load guides', 'err');
        }
      }

      async function saveGuidesJson() {
        try {
          const parsed = JSON.parse(document.getElementById('guidesEditor').value || '{}');
          await authFetch(endpoints['downloadable-guides'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(parsed),
          });
          cache.guides = parsed;
          renderGuidesList();
          setStatus('Guides JSON saved.', 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to save guides JSON', 'err');
        }
      }

      // ---------- wiring ----------

      document.getElementById('careerSaveBtn').addEventListener('click', saveCareer);
      document.getElementById('careerCancelBtn').addEventListener('click', () => {
        setCareerEditing(null);
        clearCareerForm();
        renderCareersList();
      });

      document.getElementById('catSaveBtn').addEventListener('click', saveCategory);
      document.getElementById('catCancelBtn').addEventListener('click', () => {
        setCategoryEditing(null);
        clearCategoryForm();
        renderCategoriesList();
      });

      document.getElementById('saveSettingsBtn').addEventListener('click', saveCareerSettings);
      document.getElementById('loadSettingsBtn').addEventListener('click', loadCareerSettings);

      document.getElementById('guideSaveBtn').addEventListener('click', saveGuide);
      document.getElementById('guideCancelBtn').addEventListener('click', () => {
        setGuideEditing(null);
        clearGuideForm();
        renderGuidesList();
      });
      document.getElementById('loadGuidesBtn').addEventListener('click', loadGuidesJson);
      document.getElementById('saveGuidesBtn').addEventListener('click', saveGuidesJson);

      document.getElementById('addBenefitBtn').addEventListener('click', () => {
        document.getElementById('benefitsList').appendChild(createBenefitItem());
      });
      document.getElementById('addStepBtn').addEventListener('click', () => {
        document.getElementById('appStepsList').appendChild(createStepItem());
      });

      document.getElementById('cat_name').addEventListener('input', e => {
        const slugEl = document.getElementById('cat_slug');
        if (!slugEl.dataset.touched) slugEl.value = slugify(e.target.value);
      });
      document.getElementById('cat_slug').addEventListener('input', e => {
        e.target.dataset.touched = 'true';
      });
      document.getElementById('guide_title').addEventListener('input', e => {
        const slugEl = document.getElementById('guide_slug');
        if (!slugEl.dataset.touched) slugEl.value = slugify(e.target.value);
      });
      document.getElementById('guide_slug').addEventListener('input', e => {
        e.target.dataset.touched = 'true';
      });

      if (!getToken()) {
        window.location.href = '/admin';
      }

      activateTab('careers');
      refreshCategoriesList();
      document.getElementById('benefitsList').appendChild(createBenefitItem());
      document.getElementById('appStepsList').appendChild(createStepItem());
    </script>
  </body>
</html>
