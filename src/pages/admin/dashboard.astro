---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ATEK CMS Dashboard</title>
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: #f1f5f9;
        color: #0f172a;
      }
      .shell {
        display: flex;
        min-height: 100vh;
        align-items: flex-start;
      }
      .sidebar {
        width: 260px;
        flex: 0 0 260px;
        min-height: 100vh;
        background: #0f172a;
        color: #e2e8f0;
        padding: 20px 14px;
        position: sticky;
        top: 0;
      }
      .sidebar h1 {
        font-size: 16px;
        margin: 4px 8px 18px;
        color: #fff;
      }
      .nav-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        text-align: left;
        border: none;
        background: transparent;
        color: #cbd5e1;
        padding: 11px 12px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        margin-bottom: 4px;
      }
      .nav-btn:hover { background: #1e293b; color: #fff; }
      .nav-btn.active { background: #0284c7; color: #fff; }
      .sidebar-footer {
        margin-top: 24px;
        padding-top: 14px;
        border-top: 1px solid #1e293b;
      }
      .content {
        flex: 1;
        min-width: 0;
        padding: 24px;
      }
      .content-inner {
        max-width: 1000px;
        margin: 0 auto;
      }
      .card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 18px;
        margin-bottom: 16px;
      }
      .row { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
      .row-between { display: flex; justify-content: space-between; align-items: center; gap: 8px; flex-wrap: wrap; }
      .grid { display: grid; gap: 12px; }
      .cols-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
      .cols-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
      .hidden { display: none; }
      .btn {
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 9px 14px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        background: #f8fafc;
      }
      .btn-primary { background: #0284c7; color: #ffffff; border-color: #0284c7; }
      .btn-success { background: #059669; color: #ffffff; border-color: #059669; }
      .btn-danger { background: #dc2626; color: #ffffff; border-color: #dc2626; }
      .btn-sm { padding: 6px 10px; font-size: 12px; }
      .btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .subhead { margin: 6px 0; font-size: 14px; color: #0f172a; font-weight: 700; }
      .section-title { margin: 0 0 4px; font-size: 20px; }
      .section-desc { margin: 0 0 14px; color: #64748b; font-size: 13px; }
      .field-label { font-size: 12px; color: #475569; margin: 0 0 6px; font-weight: 600; }
      input, textarea, select {
        width: 100%;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background: #ffffff;
        color: #0f172a;
        padding: 10px;
        font: inherit;
      }
      textarea { min-height: 90px; }
      textarea.json { min-height: 240px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
      .status { margin-top: 10px; color: #b45309; min-height: 20px; font-size: 14px; }
      .status.ok { color: #059669; }
      .status.err { color: #dc2626; }
      .repeat-item {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px;
        background: #f8fafc;
      }
      .list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 14px;
      }
      .list-vertical {
        grid-template-columns: 1fr;
      }
      .list-vertical .list-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 12px;
      }
      .list-vertical .list-card-header,
      .list-vertical .list-item-meta {
        grid-column: 1;
      }
      .list-vertical .list-card-actions {
        grid-column: 2;
        grid-row: 1 / span 2;
        border-top: 0;
        padding-top: 0;
        margin-top: 0;
        min-width: 160px;
      }
      .btn-edit {
        background: #2563eb !important;
        color: #ffffff !important;
        border-color: #2563eb !important;
      }
      .btn-edit:hover {
        background: #1d4ed8 !important;
        border-color: #1d4ed8 !important;
      }
      .btn-delete {
        background: #dc2626 !important;
        color: #ffffff !important;
        border-color: #dc2626 !important;
      }
      .btn-delete:hover {
        background: #b91c1c !important;
        border-color: #b91c1c !important;
      }
      .list-card-actions .btn {
        min-height: 32px;
        font-weight: 700;
      }
      .list-item {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 10px;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px;
        background: #ffffff;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        transition: box-shadow 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
      }
      .list-item:hover {
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.08);
        transform: translateY(-1px);
        border-color: #cbd5e1;
      }
      .list-item.editing { border-color: #0284c7; background: #eff6ff; box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12); }
      .list-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
      .list-item-title { font-weight: 700; font-size: 14.5px; line-height: 1.35; color: #0f172a; }
      .list-item-meta {
        font-size: 12px;
        color: #64748b;
        display: flex;
        flex-wrap: wrap;
        gap: 4px 6px;
      }
      .list-item-meta span:not(:last-child)::after { content: '·'; margin-left: 6px; color: #cbd5e1; }
      .list-card-actions {
        display: flex;
        gap: 8px;
        margin-top: auto;
        padding-top: 10px;
        border-top: 1px solid #eef2f7;
      }
      .list-card-actions .btn { flex: 1; }
      .badge {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        padding: 3px 9px;
        border-radius: 999px;
        background: #e2e8f0;
        color: #334155;
        white-space: nowrap;
      }
      .badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        opacity: 0.7;
      }
      .badge.on { background: #dcfce7; color: #166534; }
      .badge.off { background: #fee2e2; color: #991b1b; }
      .career-groups { display: grid; gap: 22px; }
      .career-group-header {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        font-size: 14px;
        color: #0f172a;
        margin-bottom: 10px;
        padding-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
      }
      .career-group-count {
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        background: #e2e8f0;
        border-radius: 999px;
        padding: 2px 8px;
      }
      .career-group-list { margin-bottom: 0; }
      .empty-state {
        text-align: center;
        color: #94a3b8;
        padding: 24px;
        font-size: 13px;
        border: 1px dashed #cbd5e1;
        border-radius: 10px;
      }
      details.advanced { margin-top: 4px; }
      details.advanced summary {
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
      }
      @media (max-width: 900px) {
        .shell { flex-direction: column; }
        .sidebar { width: 100%; flex: none; position: static; min-height: auto; }
        .nav-btn { display: inline-flex; width: auto; }
        .row#navRow { flex-direction: row; overflow-x: auto; }
        .cols-2, .cols-3 { grid-template-columns: 1fr; }
        .list-vertical .list-item {
          grid-template-columns: 1fr;
        }
        .list-vertical .list-card-actions {
          grid-column: 1;
          grid-row: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <h1>ATEK CMS</h1>
        <div class="row" id="navRow" style="flex-direction: column; align-items: stretch;">
          <button class="nav-btn active" data-key="careers">Careers</button>
          <button class="nav-btn" data-key="job-categories">Job Categories</button>
          <button class="nav-btn" data-key="applications">Applications</button>
          <button class="nav-btn" data-key="career-page-settings">Career Page Settings</button>
          <button class="nav-btn" data-key="downloadable-guides">Downloadable Guides</button>
        </div>
        <div class="sidebar-footer">
          <button id="logoutBtn" class="btn btn-danger" style="width: 100%;">Logout</button>
        </div>
      </aside>

      <main class="content">
        <div class="content-inner">

          <!-- CAREERS -->
          <section id="careersTab" class="grid">
            <div class="card">
              <h2 class="section-title">Careers</h2>
              <p class="section-desc">Existing job postings. Click Edit to update, or Delete to remove.</p>
              <div id="careersList" class="list"></div>
            </div>

            <div class="card grid">
              <h3 style="margin:0;" id="careerFormTitle">Add Career (Job Posting)</h3>
              <div class="subhead">Basic Information</div>
              <div class="cols-3">
                <div><p class="field-label">Job Title *</p><input id="career_jobTitle" /></div>
                <div><p class="field-label">Job Code</p><input id="career_jobCode" /></div>
                <div><p class="field-label">Category *</p><select id="career_category"><option value="">Select category</option></select></div>
                <div><p class="field-label">Seniority Level *</p><select id="career_seniority"><option>Entry Level</option><option>Junior</option><option>Mid Level</option><option>Senior Level</option><option>Lead</option><option>Manager</option></select></div>
                <div><p class="field-label">Employment Type *</p><select id="career_employmentType"><option>Full-Time</option><option>Part-Time</option><option>Contract</option><option>Internship</option><option>Temporary</option><option>Freelance</option></select></div>
              </div>
              <div class="subhead">Location</div>
              <div class="cols-3">
                <div><p class="field-label">Country</p><input id="career_country" /></div>
                <div><p class="field-label">State</p><input id="career_state" /></div>
                <div><p class="field-label">City</p><input id="career_city" /></div>
                <div><p class="field-label">Office Location</p><input id="career_officeLocation" /></div>
                <div><p class="field-label">Work Mode *</p><select id="career_workMode"><option>On-site</option><option>Remote</option><option>Hybrid</option></select></div>
              </div>
              <div class="subhead">Salary</div>
              <div class="cols-3">
                <div><p class="field-label">Salary</p><input id="career_salary" /></div>
                <div><p class="field-label">Salary Type</p><select id="career_salaryType"><option>Annual</option><option>Monthly</option><option>Hourly</option></select></div>
                <div><p class="field-label">Currency</p><input id="career_currency" /></div>
              </div>
              <div class="subhead">Experience & Education</div>
              <div class="cols-2">
                <div><p class="field-label">Experience Required</p><input id="career_experienceRequired" /></div>
                <div><p class="field-label">Education Required</p><input id="career_educationRequired" /></div>
              </div>
              <div class="subhead">Job Content</div>
              <div><p class="field-label">Short Description</p><textarea id="career_shortDescription"></textarea></div>
              <div><p class="field-label">Job Description</p><textarea id="career_description"></textarea></div>
              <div><p class="field-label">Responsibilities</p><textarea id="career_responsibilities"></textarea></div>
              <div><p class="field-label">Requirements</p><textarea id="career_requirements"></textarea></div>
              <div><p class="field-label">Preferred Qualifications</p><textarea id="career_preferredQualifications"></textarea></div>
              <div class="subhead">Skills</div>
              <div class="cols-2">
                <div><p class="field-label">Required Skills (comma separated)</p><input id="career_requiredSkills" /></div>
                <div><p class="field-label">Technologies (comma separated)</p><input id="career_technologies" /></div>
              </div>
              <div class="subhead">Application Details</div>
              <div class="cols-3">
                <div><p class="field-label">Application Email</p><input id="career_applicationEmail" type="email" /></div>
                <div><p class="field-label">External Apply URL</p><input id="career_externalUrl" type="url" /></div>
                <div><p class="field-label">Application Deadline</p><input id="career_deadline" type="date" /></div>
                <div><p class="field-label">Number of Openings</p><input id="career_openings" type="number" min="0" /></div>
              </div>
              <div class="subhead">Status</div>
              <div class="cols-3">
                <label><input id="career_featured" type="checkbox" /> Featured Job</label>
                <label><input id="career_urgent" type="checkbox" /> Urgent Hiring</label>
                <label><input id="career_published" type="checkbox" checked /> Published</label>
              </div>
              <div class="cols-3">
                <div><p class="field-label">Display Order</p><input id="career_displayOrder" type="number" min="0" /></div>
              </div>
              <div class="row">
                <button id="careerSaveBtn" class="btn btn-primary">Add Career</button>
                <button id="careerCancelBtn" class="btn hidden">Cancel Edit</button>
              </div>
            </div>
          </section>

          <!-- APPLICATIONS -->
          <section id="applicationsTab" class="grid hidden">
            <div class="card">
              <h2 class="section-title">Job Applications</h2>
              <p class="section-desc">Review submitted applications, approve/reject, and download resumes.</p>
              <div id="applicationsList" class="list list-vertical"></div>
            </div>
          </section>

          <!-- JOB CATEGORIES -->
          <section id="jobCategoriesTab" class="grid hidden">
            <div class="card">
              <h2 class="section-title">Job Categories</h2>
              <p class="section-desc">Existing job categories. Click Edit to update, or Delete to remove.</p>
              <div id="categoriesList" class="list list-vertical"></div>
            </div>

            <div class="card grid">
              <h3 style="margin:0;" id="catFormTitle">Add Job Category</h3>
              <div class="cols-2">
                <div><p class="field-label">Category Name *</p><input id="cat_name" /></div>
                <div><p class="field-label">Slug</p><input id="cat_slug" /></div>
                <div style="grid-column:1/-1;"><p class="field-label">Short Description</p><textarea id="cat_description"></textarea></div>
                <div><p class="field-label">Category Icon</p><input id="cat_icon" /></div>
                <div><p class="field-label">Category Banner Image</p><input id="cat_banner" /></div>
                <div><p class="field-label">Display Order</p><input id="cat_order" type="number" min="0" /></div>
                <div><p class="field-label">Status *</p><select id="cat_status"><option>Active</option><option>Inactive</option></select></div>
                <div><label><input id="cat_showCareers" type="checkbox" checked /> Show on Careers Page</label></div>
              </div>
              <div class="row">
                <button id="catSaveBtn" class="btn btn-primary">Add Job Category</button>
                <button id="catCancelBtn" class="btn hidden">Cancel Edit</button>
              </div>
            </div>
          </section>

          <!-- CAREER PAGE SETTINGS -->
          <section id="careerSettingsTab" class="grid hidden">
            <div class="card grid">
              <h2 class="section-title" style="margin-bottom:0;">Career Page Settings</h2>
              <div class="subhead">Hero Section</div>
              <div class="cols-2">
                <div><p class="field-label">Hero Title *</p><input id="set_heroTitle" /></div>
                <div><p class="field-label">Hero Banner Image</p><input id="set_heroBannerImage" /></div>
                <div style="grid-column:1/-1;"><p class="field-label">Hero Subtitle *</p><textarea id="set_heroSubtitle"></textarea></div>
                <div><p class="field-label">Hero Background Image</p><input id="set_heroBackgroundImage" /></div>
              </div>

              <div class="subhead">Why Join Section</div>
              <div class="cols-2">
                <div><p class="field-label">Section Title *</p><input id="set_whyTitle" /></div>
                <div style="grid-column:1/-1;"><p class="field-label">Section Description *</p><textarea id="set_whyDescription"></textarea></div>
              </div>

              <div class="subhead">Benefits</div>
              <div id="benefitsList" class="grid"></div>
              <div class="row"><button id="addBenefitBtn" class="btn">Add Benefit</button></div>

              <div class="subhead">Application Process</div>
              <div id="appStepsList" class="grid"></div>
              <div class="row"><button id="addStepBtn" class="btn">Add Step</button></div>

              <div class="subhead">Contact Information</div>
              <div class="cols-2">
                <div><p class="field-label">Contact Email</p><input id="set_contactEmail" type="email" /></div>
                <div><p class="field-label">Office Location</p><input id="set_officeLocation" /></div>
                <div><p class="field-label">Contact Phone</p><input id="set_contactPhone" /></div>
                <div><p class="field-label">Google Maps Link</p><input id="set_googleMaps" /></div>
              </div>

              <div class="subhead">Equal Opportunity Statement</div>
              <div><p class="field-label">Equal Opportunity Content</p><textarea id="set_equalOpportunity"></textarea></div>

              <div class="subhead">Career Page Visibility Settings</div>
              <div class="cols-3">
                <label><input id="set_enableCareerPage" type="checkbox" checked /> Enable Career Page</label>
                <label><input id="set_showOpenPositions" type="checkbox" checked /> Show Open Positions Section</label>
                <label><input id="set_showBenefits" type="checkbox" checked /> Show Benefits Section</label>
                <label><input id="set_showApplicationProcess" type="checkbox" checked /> Show Application Process</label>
                <label><input id="set_showContact" type="checkbox" checked /> Show Contact Section</label>
                <label><input id="set_showDownloads" type="checkbox" checked /> Show Downloads Section</label>
              </div>

              <div class="subhead">SEO</div>
              <div class="cols-2">
                <div><p class="field-label">SEO Title</p><input id="set_seoTitle" /></div>
                <div><p class="field-label">Open Graph Image</p><input id="set_ogImage" /></div>
                <div style="grid-column:1/-1;"><p class="field-label">SEO Description</p><textarea id="set_seoDescription"></textarea></div>
                <div style="grid-column:1/-1;"><p class="field-label">SEO Keywords (comma separated)</p><input id="set_seoKeywords" /></div>
              </div>

              <div class="row">
                <button id="loadSettingsBtn" class="btn">Reload Settings</button>
                <button id="saveSettingsBtn" class="btn btn-success">Save Settings</button>
              </div>
            </div>
          </section>

          <!-- DOWNLOADABLE GUIDES -->
          <section id="guidesTab" class="grid hidden">
            <div class="card">
              <h2 class="section-title">Downloadable Guides</h2>
              <p class="section-desc">Existing guides. Click Edit to update, or Delete to remove.</p>
              <div id="guidesList" class="list"></div>
            </div>

            <div class="card grid">
              <h3 style="margin:0;" id="guideFormTitle">Add Downloadable Guide</h3>
              <div class="subhead">Basic Information</div>
              <div class="cols-2">
                <div><p class="field-label">Guide Title *</p><input id="guide_title" /></div>
                <div><p class="field-label">Slug</p><input id="guide_slug" /></div>
                <div style="grid-column:1/-1;"><p class="field-label">Short Description *</p><textarea id="guide_description"></textarea></div>
                <div><p class="field-label">Category</p><select id="guide_category"><option>SaaS</option><option>DevOps</option><option>Cloud</option><option>Pay Pilot</option><option>AI</option><option>Security</option><option>Engineering</option><option>Business</option><option>Product</option><option>Other</option></select></div>
                <div><p class="field-label">Guide Type</p><select id="guide_type"><option>Guide</option><option>Checklist</option><option>Toolkit</option><option>Workbook</option><option>Whitepaper</option><option>eBook</option><option>Template</option><option>Case Study</option></select></div>
              </div>

              <div class="subhead">Media</div>
              <div class="cols-2">
                <div><p class="field-label">Thumbnail Image</p><input id="guide_thumbnail" /></div>
                <div><p class="field-label">Cover Image</p><input id="guide_cover" /></div>
                <div><p class="field-label">Guide File</p><input id="guide_file" /></div>
              </div>

              <div class="subhead">Download Button</div>
              <div class="cols-2">
                <div><p class="field-label">Button Text</p><input id="guide_buttonText" value="Download" /></div>
                <div><p class="field-label">External Download URL</p><input id="guide_externalUrl" /></div>
              </div>

              <div class="subhead">Display Settings</div>
              <div class="cols-3">
                <label><input id="guide_featured" type="checkbox" /> Featured Guide</label>
                <div><p class="field-label">Display Order</p><input id="guide_order" type="number" min="0" value="1" /></div>
                <div><p class="field-label">Status</p><select id="guide_status"><option>Active</option><option>Inactive</option></select></div>
              </div>

              <div class="subhead">Analytics</div>
              <div class="cols-2">
                <label><input id="guide_trackDownloads" type="checkbox" checked /> Track Downloads</label>
                <div><p class="field-label">Download Count</p><input id="guide_downloadCount" type="number" value="0" /></div>
              </div>

              <div class="subhead">SEO</div>
              <div class="cols-2">
                <div><p class="field-label">SEO Title</p><input id="guide_seoTitle" /></div>
                <div style="grid-column:1/-1;"><p class="field-label">SEO Description</p><textarea id="guide_seoDescription"></textarea></div>
                <div style="grid-column:1/-1;"><p class="field-label">SEO Keywords (comma separated)</p><input id="guide_seoKeywords" /></div>
              </div>

              <div class="row">
                <button id="guideSaveBtn" class="btn btn-primary">Add Guide</button>
                <button id="guideCancelBtn" class="btn hidden">Cancel Edit</button>
              </div>

              <details class="advanced">
                <summary>Advanced: edit raw JSON</summary>
                <div class="row" style="margin-top:10px;">
                  <button id="loadGuidesBtn" class="btn">Reload Guides JSON</button>
                  <button id="saveGuidesBtn" class="btn btn-success">Save Guides JSON</button>
                </div>
                <textarea id="guidesEditor" class="json" style="margin-top:10px;">{}</textarea>
              </details>
            </div>
          </section>

          <p id="status" class="status"></p>
        </div>
      </main>
    </div>

    <script>
      const STORAGE_KEY = 'atek-firebase-cms-token';
      const endpoints = {
        'careers': '/api/admin/careers',
        'job-categories': '/api/admin/job-categories',
        'applications': '/api/admin/job-applications',
        'career-page-settings': '/api/admin/career-page-settings',
        'downloadable-guides': '/api/admin/downloadable-guides',
      };

      const statusEl = document.getElementById('status');
      const navBtns = document.querySelectorAll('.nav-btn');
      const sections = {
        careers: document.getElementById('careersTab'),
        'job-categories': document.getElementById('jobCategoriesTab'),
        applications: document.getElementById('applicationsTab'),
        'career-page-settings': document.getElementById('careerSettingsTab'),
        'downloadable-guides': document.getElementById('guidesTab'),
      };

      // key of the item currently being edited, per entity (null = adding new)
      const editState = { careers: null, categories: null, guides: null };
      // in-memory cache of the last-loaded full object per entity
      const cache = { careers: {}, categories: {}, guides: {}, applications: [] };
      const uiState = { expandedApplicationId: null };

      function setStatus(message, kind) {
        statusEl.textContent = message || '';
        statusEl.className = 'status' + (kind ? ' ' + kind : '');
      }

      function getToken() {
        return localStorage.getItem(STORAGE_KEY) || '';
      }

      function slugify(value) {
        return String(value || '')
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');
      }

      function splitTags(raw) {
        return String(raw || '').split(',').map(x => x.trim()).filter(Boolean);
      }

      function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, ch => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        }[ch]));
      }

      async function authFetch(url, options = {}) {
        const token = getToken();
        if (!token) {
          window.location.href = '/admin';
          throw new Error('Missing session token');
        }
        const headers = Object.assign({}, options.headers || {}, { Authorization: 'Bearer ' + token });
        const response = await fetch(url, Object.assign({}, options, { headers }));
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || 'Request failed');
        return payload;
      }

      function activateTab(key) {
        Object.keys(sections).forEach(sectionKey => {
          sections[sectionKey].classList.toggle('hidden', sectionKey !== key);
        });
        navBtns.forEach(btn => btn.classList.toggle('active', btn.getAttribute('data-key') === key));

        if (key === 'careers') refreshCareersList();
        if (key === 'job-categories') refreshCategoriesList();
        if (key === 'applications') refreshApplicationsList();
        if (key === 'downloadable-guides') refreshGuidesList();
        if (key === 'career-page-settings') loadCareerSettings();
      }

      function renderApplicationsList() {
        const container = document.getElementById('applicationsList');
        const items = Array.isArray(cache.applications) ? cache.applications : [];

        if (!items.length) {
          container.innerHTML = '<div class="empty-state">No applications submitted yet.</div>';
          return;
        }

        container.innerHTML = '';

        items.forEach(item => {
          const isExpanded = uiState.expandedApplicationId === item.id;
          const row = document.createElement('div');
          row.className = 'list-item';

          const statusClass = item.status === 'approved' ? 'on' : item.status === 'rejected' ? 'off' : '';
          const createdAt = item.createdAt ? new Date(item.createdAt).toLocaleString() : 'Unknown';
          const resumeText = item.resume?.filename
            ? `${item.resume.filename} (${Math.round((Number(item.resume.size || 0) / 1024) || 0)} KB)`
            : 'No resume';

          row.innerHTML = `
            <div class="list-card-header">
              <div class="list-item-title">${escapeHtml(item.name || 'Unknown applicant')}</div>
              <span class="badge ${statusClass}">${escapeHtml(item.status || 'pending')}</span>
            </div>
            <div class="list-item-meta">
              <span>${escapeHtml(item.jobRole || 'Unspecified role')}</span>
              <span>${escapeHtml(item.email || '-')}</span>
              <span>${escapeHtml(item.phone || '-')}</span>
              <span>${escapeHtml(createdAt)}</span>
            </div>
            ${isExpanded ? `
              <div class="list-item-meta" style="grid-column:1/-1; border-top:1px solid #eef2f7; padding-top:10px;">
                <span>${escapeHtml(resumeText)}</span>
                ${item.updatedAt ? `<span>Updated ${escapeHtml(new Date(item.updatedAt).toLocaleString())}</span>` : ''}
              </div>
            ` : ''}
            <div class="list-card-actions">
              <button class="btn btn-sm btn-edit" data-view>${isExpanded ? 'Hide' : 'View'}</button>
              <button class="btn btn-sm btn-success" data-approve>Approve</button>
              <button class="btn btn-sm btn-danger" data-reject>Reject</button>
              <button class="btn btn-sm" data-download>Download</button>
            </div>
          `;

          row.querySelector('[data-view]').addEventListener('click', () => {
            uiState.expandedApplicationId = isExpanded ? null : item.id;
            renderApplicationsList();
          });

          row.querySelector('[data-approve]').addEventListener('click', () => updateApplicationStatus(item.id, 'approved'));
          row.querySelector('[data-reject]').addEventListener('click', () => updateApplicationStatus(item.id, 'rejected'));
          row.querySelector('[data-download]').addEventListener('click', () => {
            downloadApplicationResume(item.id);
          });

          container.appendChild(row);
        });
      }

      async function refreshApplicationsList() {
        try {
          const data = await authFetch(endpoints['applications']);
          cache.applications = Array.isArray(data) ? data : [];
          renderApplicationsList();
        } catch (error) {
          setStatus(error.message || 'Failed to load applications', 'err');
        }
      }

      async function updateApplicationStatus(id, status) {
        try {
          await authFetch(endpoints['applications'], {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, status }),
          });

          const target = cache.applications.find(item => item.id === id);
          if (target) {
            target.status = status;
            target.updatedAt = new Date().toISOString();
          }

          renderApplicationsList();
          setStatus(`Application marked as ${status}.`, 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to update status', 'err');
        }
      }

      async function downloadApplicationResume(id) {
        try {
          const token = getToken();
          const response = await fetch(`/api/admin/job-applications/${encodeURIComponent(id)}/resume`, {
            headers: { Authorization: 'Bearer ' + token },
          });

          if (!response.ok) {
            const payload = await response.json().catch(() => ({}));
            throw new Error(payload.error || 'Failed to download resume');
          }

          const disposition = response.headers.get('Content-Disposition') || '';
          const filenameMatch = disposition.match(/filename="([^"]+)"/i);
          const filename = filenameMatch ? filenameMatch[1] : `resume-${id}`;
          const blob = await response.blob();
          const url = URL.createObjectURL(blob);
          const anchor = document.createElement('a');
          anchor.href = url;
          anchor.download = filename;
          document.body.appendChild(anchor);
          anchor.click();
          anchor.remove();
          URL.revokeObjectURL(url);
        } catch (error) {
          setStatus(error.message || 'Failed to download resume', 'err');
        }
      }

      navBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          activateTab(btn.getAttribute('data-key'));
        });
      });

      document.getElementById('logoutBtn').addEventListener('click', () => {
        localStorage.removeItem(STORAGE_KEY);
        window.location.href = '/admin';
      });

      // ---------- CAREERS ----------

      function populateCareerForm(item) {
        syncCareerCategoryOptions(item.category || item.jobCategory || '');
        document.getElementById('career_jobTitle').value = item.title || '';
        document.getElementById('career_jobCode').value = item.jobCode || '';
        document.getElementById('career_category').value = item.category || item.jobCategory || '';
        document.getElementById('career_seniority').value = item.seniorityLevel || '';
        document.getElementById('career_employmentType').value = item.employmentType || item.type || '';
        document.getElementById('career_country').value = item.country || '';
        document.getElementById('career_state').value = item.state || '';
        document.getElementById('career_city').value = item.city || '';
        document.getElementById('career_officeLocation').value = item.officeLocation || '';
        document.getElementById('career_workMode').value = item.workMode || '';
        document.getElementById('career_salary').value = item.salary || '';
        document.getElementById('career_salaryType').value = item.salaryType || '';
        document.getElementById('career_currency').value = item.currency || '';
        document.getElementById('career_experienceRequired').value = item.experienceRequired || '';
        document.getElementById('career_educationRequired').value = item.educationRequired || '';
        document.getElementById('career_shortDescription').value = item.shortDescription || '';
        document.getElementById('career_description').value = item.description || '';
