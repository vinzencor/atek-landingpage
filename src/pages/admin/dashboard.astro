      function clearCareerForm() {
        ['career_jobTitle','career_jobCode','career_country','career_state','career_city','career_officeLocation',
         'career_salary','career_currency','career_experienceRequired','career_educationRequired',
         'career_shortDescription','career_description','career_responsibilities','career_requirements',
         'career_preferredQualifications','career_requiredSkills','career_technologies','career_applicationEmail',
         'career_externalUrl','career_deadline'].forEach(id => { document.getElementById(id).value = ''; });
        document.getElementById('career_openings').value = '';
        document.getElementById('career_displayOrder').value = '';
        document.getElementById('career_featured').checked = false;
        document.getElementById('career_urgent').checked = false;
        document.getElementById('career_published').checked = true;
        document.getElementById('career_category').selectedIndex = 0;
        document.getElementById('career_seniority').selectedIndex = 0;
        document.getElementById('career_employmentType').selectedIndex = 0;
        document.getElementById('career_workMode').selectedIndex = 0;
        document.getElementById('career_salaryType').selectedIndex = 0;
      }

      function syncCareerCategoryOptions(selectedValue) {
        const selectEl = document.getElementById('career_category');
        const currentValue = selectedValue ?? selectEl.value;
        const categories = Object.values(cache.categories || {})
          .filter(item => item && item.name)
          .sort((a, b) => Number(a.order || 0) - Number(b.order || 0));

        const options = ['<option value="">Select category</option>'];
        categories.forEach(item => {
          options.push(`<option value="${escapeHtml(item.name)}">${escapeHtml(item.name)}</option>`);
        });

        if (currentValue && !categories.some(item => item.name === currentValue)) {
          options.push(`<option value="${escapeHtml(currentValue)}">${escapeHtml(currentValue)}</option>`);
        }

        selectEl.innerHTML = options.join('');
        if (currentValue) selectEl.value = currentValue;
      }

      function setCareerEditing(key) {
        editState.careers = key;
        const title = document.getElementById('careerFormTitle');
        const saveBtn = document.getElementById('careerSaveBtn');
        const cancelBtn = document.getElementById('careerCancelBtn');
        if (key) {
          title.textContent = 'Edit Career (Job Posting)';
          saveBtn.textContent = 'Update Career';
          cancelBtn.classList.remove('hidden');
        } else {
          title.textContent = 'Add Career (Job Posting)';
          saveBtn.textContent = 'Add Career';
          cancelBtn.classList.add('hidden');
        }
      }

      function editCareer(key) {
        const item = cache.careers[key];
        if (!item) return;
        populateCareerForm(item);
        setCareerEditing(key);
        document.getElementById('careerFormTitle').scrollIntoView({ behavior: 'smooth', block: 'start' });
        renderCareersList();
      }

      async function deleteCareer(key) {
        const item = cache.careers[key];
        if (!confirm('Delete career "' + (item && item.title ? item.title : key) + '"? This cannot be undone.')) return;
        try {
          delete cache.careers[key];
          await authFetch(endpoints['careers'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cache.careers),
          });
          if (editState.careers === key) {
            setCareerEditing(null);
            clearCareerForm();
          }
          renderCareersList();
          setStatus('Career deleted.', 'ok');
        } catch (error) {
          setStatus(error.message || 'Failed to delete career', 'err');
        }
      }

      function buildCareerCard(key, item) {
        const meta = [item.category || item.jobCategory, item.employmentType || item.type, item.workMode]
          .filter(Boolean)
          .map(v => `<span>${escapeHtml(v)}</span>`)
          .join('');
        const row = document.createElement('div');
        row.className = 'list-item' + (editState.careers === key ? ' editing' : '');
        row.innerHTML = `
          <div class="list-card-header">
            <div class="list-item-title">${escapeHtml(item.title || key)}</div>
            <span class="badge ${item.published !== false ? 'on' : 'off'}">${item.published !== false ? 'Published' : 'Draft'}</span>
          </div>
          <div class="list-item-meta">${meta || '<span>No details set</span>'}</div>
          <div class="list-card-actions">
            <button class="btn btn-sm btn-edit" data-edit>Edit</button>
            <button class="btn btn-sm btn-delete" data-delete>Delete</button>
          </div>
        `;
        row.querySelector('[data-edit]').addEventListener('click', () => editCareer(key));
        row.querySelector('[data-delete]').addEventListener('click', () => deleteCareer(key));
        return row;
      }

      function renderCareersList() {
        const container = document.getElementById('careersList');
        const keys = Object.keys(cache.careers || {});
        if (!keys.length) {
          container.innerHTML = '<div class="empty-state">No careers yet. Use the form below to add one.</div>';
          return;
        }
        container.innerHTML = '';
        container.classList.remove('list');
        container.classList.add('career-groups');

        const categoryOrder = Object.values(cache.categories || {})
          .filter(item => item && item.name)
          .sort((a, b) => Number(a.order || 0) - Number(b.order || 0))
          .map(item => item.name);

        const groups = new Map();
        keys.forEach(key => {
          const item = cache.careers[key] || {};
          const groupName = item.category || item.jobCategory || 'Uncategorized';
          if (!groups.has(groupName)) groups.set(groupName, []);
          groups.get(groupName).push(key);
        });

        const orderedGroupNames = [
          ...categoryOrder.filter(name => groups.has(name)),
          ...Array.from(groups.keys()).filter(name => !categoryOrder.includes(name)),
        ];

        orderedGroupNames.forEach(groupName => {
          const groupKeys = groups.get(groupName);
          const section = document.createElement('div');
          section.className = 'career-group';
          section.innerHTML = `
            <div class="career-group-header">
              <span>${escapeHtml(groupName)}</span>
              <span class="career-group-count">${groupKeys.length}</span>
            </div>
            <div class="list career-group-list"></div>
          `;
          const listEl = section.querySelector('.career-group-list');
          groupKeys.forEach(key => {
            listEl.appendChild(buildCareerCard(key, cache.careers[key] || {}));
          });
          container.appendChild(section);
        });
      }

      async function refreshCareersList() {
        try {
          const [careersData, categoriesData] = await Promise.all([
            authFetch(endpoints['careers']),
            Object.keys(cache.categories || {}).length ? Promise.resolve(cache.categories) : authFetch(endpoints['job-categories']),
          ]);
          cache.careers = Array.isArray(careersData) ? {} : Object.assign({}, careersData || {});
          cache.categories = Array.isArray(categoriesData) ? {} : Object.assign({}, categoriesData || {});
          renderCareersList();
        } catch (error) {
          setStatus(error.message || 'Failed to load careers', 'err');
        }
      }

      async function saveCareer() {
        try {
          const title = document.getElementById('career_jobTitle').value.trim();
          if (!title) throw new Error('Job Title is required');
          const jobCode = document.getElementById('career_jobCode').value.trim();
          const key = editState.careers || slugify(jobCode || title);
          const category = document.getElementById('career_category').value;
          const seniority = document.getElementById('career_seniority').value;
          const employmentType = document.getElementById('career_employmentType').value;
          const country = document.getElementById('career_country').value.trim();
          const state = document.getElementById('career_state').value.trim();
          const city = document.getElementById('career_city').value.trim();
          const officeLocation = document.getElementById('career_officeLocation').value.trim();
          const workMode = document.getElementById('career_workMode').value;
          const salary = document.getElementById('career_salary').value.trim();
          const salaryType = document.getElementById('career_salaryType').value;
          const currency = document.getElementById('career_currency').value.trim();
          const experienceRequired = document.getElementById('career_experienceRequired').value.trim();
          const educationRequired = document.getElementById('career_educationRequired').value.trim();
          const shortDescription = document.getElementById('career_shortDescription').value.trim();
          const description = document.getElementById('career_description').value.trim();
          const responsibilities = document.getElementById('career_responsibilities').value.trim();
          const requirements = document.getElementById('career_requirements').value.trim();
          const preferredQualifications = document.getElementById('career_preferredQualifications').value.trim();
          const requiredSkills = splitTags(document.getElementById('career_requiredSkills').value);
          const technologies = splitTags(document.getElementById('career_technologies').value);
          const applicationEmail = document.getElementById('career_applicationEmail').value.trim();
          const externalApplyUrl = document.getElementById('career_externalUrl').value.trim();
          const applicationDeadline = document.getElementById('career_deadline').value;
          const numberOfOpenings = Number(document.getElementById('career_openings').value || 0);
          const featured = document.getElementById('career_featured').checked;
          const urgentHiring = document.getElementById('career_urgent').checked;
          const published = document.getElementById('career_published').checked;
          const displayOrder = Number(document.getElementById('career_displayOrder').value || 0);

          const existing = editState.careers ? (cache.careers[editState.careers] || {}) : {};

          cache.careers[key] = Object.assign({}, existing, {
            slug: key,
            title,
            jobCode,
            category,
            jobCategory: category,
            seniorityLevel: seniority,
            employmentType,
            type: employmentType,
            country,
            state,
            city,
            officeLocation,
            workMode,
            location: [city, state, country].filter(Boolean).join(', ') || officeLocation || workMode,
            salary,
            salaryType,
            currency,
            experienceRequired,
            educationRequired,
            shortDescription,
            description: description || shortDescription,
            responsibilities,
            requirements,
            preferredQualifications,
            requiredSkills,
            technologies,
            skills: requiredSkills,
            applicationEmail,
            externalApplyUrl,
            applicationDeadline,
            numberOfOpenings,
            featured,
            urgentHiring,
            published,
            displayOrder,
            date: existing.date || new Date().toISOString(),
          });

          await authFetch(endpoints['careers'], {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(cache.careers),
          });

          setStatus(editState.careers ? 'Career updated successfully.' : 'Career added successfully.', 'ok');
          setCareerEditing(null);
          clearCareerForm();
          renderCareersList();
        } catch (error) {
          setStatus(error.message || 'Failed to save career', 'err');
        }
      }

