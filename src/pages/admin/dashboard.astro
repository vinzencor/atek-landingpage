        document.getElementById('career_technologies').value = Array.isArray(item.technologies) ? item.technologies.join(', ') : '';
        document.getElementById('career_applicationEmail').value = item.applicationEmail || '';
        document.getElementById('career_externalUrl').value = item.externalApplyUrl || '';
        document.getElementById('career_deadline').value = item.applicationDeadline || '';
        document.getElementById('career_openings').value = item.numberOfOpenings || 0;
        document.getElementById('career_featured').checked = !!item.featured;
        document.getElementById('career_urgent').checked = !!item.urgentHiring;
        document.getElementById('career_published').checked = item.published !== false;
        document.getElementById('career_displayOrder').value = item.displayOrder || 0;
