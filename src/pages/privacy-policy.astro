---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Privacy Policy - ATEK IT | Data Protection & Privacy"
  description="ATEK IT's Privacy Policy explains how we collect, use, disclose, and safeguard your information when you interact with our website and services."
  keywords="privacy policy, data protection, GDPR, personal information, ATEK IT privacy"
>
  <Header />
  
  <main class="pt-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Privacy Policy</h1>
        <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-4 text-gray-600">
          <p><strong>Effective Date:</strong> June 2025</p>
          <span class="hidden sm:inline">•</span>
          <p><strong>Last Updated:</strong> November 2025</p>
        </div>
      </div>

      <!-- Introduction -->
      <div class="prose prose-lg max-w-none">
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          ATEK IT Inc ("ATEK IT," "we," "our," or "us") respects your privacy and is committed to protecting the personal information you share with us. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you interact with our website, digital forms, and services.
        </p>

        <!-- Section 1 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">1. Information We Collect</h2>
          <p class="text-gray-700 mb-4">We may collect the following categories of information:</p>
          
          <h3 class="text-xl font-semibold text-gray-900 mb-3">1.1 Personal Information</h3>
          <ul class="list-disc pl-6 mb-6 text-gray-700 space-y-2">
            <li>Full name</li>
            <li>Email address</li>
            <li>Company name</li>
            <li>Job title or designation</li>
            <li>Phone number</li>
            <li>Project or service requirements you submit through forms</li>
          </ul>

          <h3 class="text-xl font-semibold text-gray-900 mb-3">1.2 Technical Information</h3>
          <ul class="list-disc pl-6 mb-6 text-gray-700 space-y-2">
            <li>IP address</li>
            <li>Browser type and version</li>
            <li>Device identifiers</li>
            <li>Operating system</li>
            <li>Pages visited and time spent on the website</li>
          </ul>

          <h3 class="text-xl font-semibold text-gray-900 mb-3">1.3 Cookies and Tracking Technologies</h3>
          <p class="text-gray-700">
            We use cookies, pixels, and similar tools to improve user experience, analyze traffic, and personalize marketing. You can control cookies through your browser settings.
          </p>
        </section>

        <!-- Section 2 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">2. How We Use Your Information</h2>
          <p class="text-gray-700 mb-4">We use the collected data to:</p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2">
            <li>Provide quotes, proposals, and consultations you request</li>
            <li>Respond to your inquiries and manage client relationships</li>
            <li>Send relevant service or promotional information (only with consent)</li>
            <li>Improve website functionality and user experience</li>
            <li>Comply with legal and regulatory obligations</li>
          </ul>
        </section>

        <!-- Section 3 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">3. Legal Basis for Processing</h2>
          <p class="text-gray-700 mb-4">We process personal information based on:</p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2">
            <li>Your consent (when submitting forms or subscribing)</li>
            <li>Legitimate interest in marketing and business development</li>
            <li>Performance of a contract (providing agreed services)</li>
            <li>Legal obligation under applicable data-protection laws</li>
          </ul>
        </section>

        <!-- Section 4 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">4. Data Sharing and Disclosure</h2>
          <p class="text-gray-700 mb-4">We do not sell personal data. We may share limited information with:</p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2">
            <li>Trusted service providers (CRM, analytics, cloud hosting, email systems) bound by confidentiality agreements</li>
            <li>Legal authorities when required by law or court order</li>
          </ul>
        </section>

        <!-- Section 5 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">5. International Transfers</h2>
          <p class="text-gray-700">
            ATEK IT Inc operates in the United States and India. Data may be transferred securely between these jurisdictions for operational purposes, in accordance with applicable privacy regulations (including GDPR safeguards).
          </p>
        </section>

        <!-- Section 6 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">6. Data Retention</h2>
          <p class="text-gray-700">
            We retain personal information only as long as necessary for business, legal, or contractual purposes. You can request deletion at any time.
          </p>
        </section>

        <!-- Section 7 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">7. Your Rights</h2>
          <p class="text-gray-700 mb-4">Depending on your jurisdiction, you may have the right to:</p>
          <ul class="list-disc pl-6 text-gray-700 space-y-2">
            <li>Access, correct, or delete your personal data</li>
            <li>Withdraw consent at any time</li>
            <li>Object to or restrict certain processing activities</li>
            <li>Request data portability</li>
          </ul>
          <p class="text-gray-700 mt-4">
            To exercise these rights, email <a href="mailto:info@atekit.com" class="text-primary-600 hover:text-primary-700 underline">info@atekit.com</a>.
          </p>
        </section>

        <!-- Section 8 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">8. Data Security</h2>
          <p class="text-gray-700">
            We use SSL encryption, access control, and secure cloud storage to protect your information. While no online platform can guarantee absolute security, we continually update our practices to minimize risk.
          </p>
        </section>

        <!-- Section 9 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">9. Third-Party Links</h2>
          <p class="text-gray-700">
            Our website may link to external sites (e.g., clients, partners). We are not responsible for the privacy practices or content of those sites.
          </p>
        </section>

        <!-- Section 10 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">10. Marketing Communications</h2>
          <p class="text-gray-700">
            You may opt out of marketing emails at any time by clicking Unsubscribe or contacting us directly. Transactional and service-related emails may still be sent when necessary.
          </p>
        </section>

        <!-- Section 11 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">11. Updates to This Policy</h2>
          <p class="text-gray-700">
            We may update this Privacy Policy from time to time. Any changes will be posted on this page with an updated "Effective Date."
          </p>
        </section>

        <!-- Section 12 -->
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">12. Contact Information</h2>
          <p class="text-gray-700 mb-4">For questions, concerns, or privacy requests, contact:</p>
          <div class="bg-gray-50 border border-gray-200 rounded-lg p-6">
            <p class="font-semibold text-gray-900 mb-2">ATEK IT Inc</p>
            <p class="text-gray-700">Frisco, Texas – USA</p>
            <p class="text-gray-700">Email: <a href="mailto:info@atekit.com" class="text-primary-600 hover:text-primary-700 underline">info@atekit.com</a></p>
            <p class="text-gray-700">Website: <a href="https://www.atekit.com" class="text-primary-600 hover:text-primary-700 underline">https://www.atekit.com</a></p>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

